OPENAI_API_KEY=
# Optional — enables run_readonly_sql tool + persistent chat threads
DATABASE_URL=

# Optional overrides
OPENAI_MODEL=gpt-4o-mini
# Max tool rounds per agent request (default 24, max 64)
# MAX_TOOL_ITERATIONS=24
# Comma-separated; * allows all (take-home default)
CORS_ORIGINS=*

# Optional — used by refresh_draftkings_nba_odds tool if DraftKings requires cookies
# DK_COOKIE='ak_bmsc=...; bm_sz=...'
# DK_CLIENT_VERSION=2615.2.1.13
# DK_WIDGET_VERSION=2.9.9
# DK_INSECURE_TLS=false  # only for local cert debugging
